  @@unique([tenant_id, period_year, period_month])
  @@index([tenant_id, period_year, period_month])
  @@map("hr_payroll_periods")
}

model HrPayslip {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String @db.Uuid
  period_id   String @db.Uuid
  employee_id String @db.Uuid
  period_year  Int
  period_month Int
  // Rubriques brutes (centimes)
  gross_base_cents  Int
  overtime_cents    Int @default(0)
  bonus_cents       Int @default(0)
  indemnity_cents   Int @default(0)
  gross_total_cents Int
  // Cotisations salariales
  urssaf_employee_cents       Int
  retirement_employee_cents   Int
  unemployment_employee_cents Int @default(0)
  mutual_employee_cents       Int @default(0)
  csg_crds_cents              Int
  total_employee_deductions_cents Int
  // Net
  net_taxable_cents Int
  net_to_pay_cents  Int
  // Cotisations patronales (info)
  urssaf_employer_cents        Int
  retirement_employer_cents    Int
  unemployment_employer_cents  Int
  mutual_employer_cents        Int @default(0)
  total_employer_charges_cents Int
  // Reduction Fillon
  fillon_reduction_cents Int @default(0)
  // V5 : prevoyance
  prevoyance_employee_cents Int @default(0)
  prevoyance_employer_cents Int @default(0)
  // V5 : tickets restaurants
  tr_count            Int @default(0)
  tr_employee_cents   Int @default(0)
  tr_employer_cents   Int @default(0)
  // V6 : PAS + cumuls annuels
  pas_cents                 Int @default(0)
  ytd_gross_cents           Int @default(0)
  ytd_net_taxable_cents     Int @default(0)
  ytd_net_to_pay_cents      Int @default(0)
  // V7 : heures sup majorees + avantage nature + PPV + soldes
  overtime_25_hours         Float @default(0)
  overtime_50_hours         Float @default(0)
  overtime_25_cents         Int @default(0)
  overtime_50_cents         Int @default(0)
  benefits_in_kind_cents    Int @default(0)
  ppv_cents                 Int @default(0)
  cp_balance_end            Float @default(0)
  rtt_balance_end           Float @default(0)
  // V9 : arret maladie + transport
  sick_days_unpaid          Float @default(0)
  sick_deduction_cents      Int @default(0)
  ijss_cents                Int @default(0)
  transport_allowance_cents Int @default(0)
  // Meta
  gross_rate_cents_per_hour Int
  hours_worked              Float
  paid_leave_balance        Float @default(0)
  rtt_balance               Float @default(0)
  pdf_url                   String?
  sent_to_employee_at       DateTime?
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  period   HrPayrollPeriod @relation(fields: [period_id], references: [id])
  employee HrEmployee      @relation(fields: [employee_id], references: [id])

  @@unique([period_id, employee_id])
  @@index([tenant_id, period_year, period_month])
  @@map("hr_payslips")
}

// BUSINESS RULE [CDC-RH-V5]: Parametres paie par tenant — mutuelle / prevoyance
// Loi ANI 2013 : mutuelle collective obligatoire pour tous les salaries CDI/CDD
// Prevoyance : obligatoire pour cadres (convention 1947), facultatif autres sauf CC specifique

model HrPayrollSettings {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String @unique @db.Uuid

  // Mutuelle
  mutuelle_enabled          Boolean @default(false)
  mutuelle_employee_rate_bp Int     @default(0) // taux salarial en basis points (100 = 1%)
  mutuelle_employer_rate_bp Int     @default(0)
  mutuelle_flat_employee_cents Int @default(0) // ou montant forfaitaire (alternative au taux)
  mutuelle_flat_employer_cents Int @default(0)
  mutuelle_organisme        String? // Harmonie, Mercer, AG2R, etc.

  // Prevoyance
  prevoyance_enabled          Boolean @default(false)
  prevoyance_employee_rate_bp Int     @default(0)
  prevoyance_employer_rate_bp Int     @default(0)
  prevoyance_organisme        String?

  // Titres restaurants (bonus V5)
  tr_enabled            Boolean @default(false)
  tr_face_value_cents   Int     @default(0) // valeur faciale du titre (ex: 900 = 9 EUR)
  tr_employer_share_bp  Int     @default(5000) // 50% patronale (min 50%, max 60% exoneres)

  // V6 : taux AT-MP specifique notifie par CARSAT
  atmp_rate_bp Int @default(150) // 1.5% par defaut

  // Conformite legale bulletin (R3243-1)
  urssaf_ref             String? // ex : "URSSAF Ile-de-France - 750000000000000"
  carsat_ref             String? // reference affiliation CARSAT/CGSS
  convention_collective  String? // ex : "Convention collective nationale HCR"
  idcc                   String? // Code IDCC 4 chiffres ex : "1979"
  payment_day_of_month   Int     @default(28) // jour de paiement (25, 28, 30...)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("hr_payroll_settings")
}

