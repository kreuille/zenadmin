// Vague O3 : Indemnites kilometriques
model MileageLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  employee_id String   @db.Uuid
  date        DateTime @db.Date
  origin      String
  destination String
  purpose     String
  distance_km Decimal  @db.Decimal(6, 2)
  vehicle_cv  Int      @default(5)    // puissance fiscale (barème URSSAF)
  amount_cents Int                    // calcule depuis bareme * distance
