generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// BUSINESS RULE [R03]: Multi-tenant avec RLS - tenant_id sur chaque table
// BUSINESS RULE [R04]: Soft delete - deleted_at sur chaque table
// BUSINESS RULE [R09]: UUID pour toutes les cles primaires

model Tenant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  siret      String?  @unique
  siren      String?
  naf_code   String?
  legal_form String?
  address    Json?
  settings   Json     @default("{}")
  plan       String   @default("starter")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  users              User[]
  clients            Client[]
  products           Product[]
  quotes             Quote[]
  invoices           Invoice[]
  suppliers          Supplier[]
  purchases          Purchase[]
  bank_accounts      BankAccount[]
  duerps             Duerp[]
  rgpd_treatments    RgpdTreatment[]
  insurance_policies InsurancePolicy[]
  tenant_settings    TenantSettings[]
  hr_positions       HrPosition[]
  hr_employees       HrEmployee[]

  @@map("tenants")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  email         String
  password_hash String
  first_name    String
  last_name     String
  role          String    @default("owner")
  totp_secret   String?
  totp_enabled  Boolean   @default(false)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
  refresh_tokens RefreshToken[]

  @@unique([tenant_id, email])
  @@index([tenant_id, deleted_at])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model Client {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  type          String    @default("company")
  company_name  String?
  siret         String?
  first_name    String?
  last_name     String?
  email         String?
  phone         String?
  address_line1 String?
  address_line2 String?
  zip_code      String?
  city          String?
  country       String    @default("FR")
  notes         String?
  payment_terms Int       @default(30)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  tenant   Tenant    @relation(fields: [tenant_id], references: [id])
  quotes   Quote[]
  invoices Invoice[]

  @@index([tenant_id, deleted_at])
  @@index([tenant_id, company_name])
  @@index([tenant_id, last_name])
  @@map("clients")
}

model Product {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String    @db.Uuid
  type             String    @default("service")
  reference        String?
  name             String
  description      String?
  unit             String    @default("unit")
  unit_price_cents Int
  tva_rate         Int       @default(2000)
  category         String?
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, reference])
  @@index([tenant_id, deleted_at])
  @@index([tenant_id, category])
  @@map("products")
}

// BUSINESS RULE [CDC-2.1]: Module Ventes - Devis
model Quote {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String    @db.Uuid
  client_id         String    @db.Uuid
  number            String    // DEV-2026-00001
  status            String    @default("draft") // draft, sent, viewed, signed, refused, expired
  title             String?
  description       String?
  issue_date        DateTime  @default(now())
  validity_date     DateTime
  deposit_rate      Int?      // Taux acompte en basis points (3000 = 30%)
  discount_type     String?   // percentage, fixed
  discount_value    Int?      // Centimes ou basis points selon type
  notes             String?   // Conditions particulieres
  total_ht_cents    Int       @default(0)
  total_tva_cents   Int       @default(0)
  total_ttc_cents   Int       @default(0)
  signed_at         DateTime?
  signature_data    Json?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  tenant            Tenant    @relation(fields: [tenant_id], references: [id])
  client            Client    @relation(fields: [client_id], references: [id])
  lines             QuoteLine[]
  invoices          Invoice[]

  @@unique([tenant_id, number])
  @@index([tenant_id, deleted_at])
  @@index([tenant_id, status])
  @@index([tenant_id, client_id])
  @@map("quotes")
}

model QuoteLine {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quote_id          String  @db.Uuid
  product_id        String? @db.Uuid
  position          Int
  type              String  @default("line") // line, section, subtotal, comment
  label             String
  description       String?
  quantity          Decimal @db.Decimal(10, 3)
  unit              String  @default("unit")
  unit_price_cents  Int     @default(0)
  tva_rate          Int     @default(2000)
  discount_type     String? // percentage, fixed
  discount_value    Int?
  total_ht_cents    Int     @default(0)

  quote             Quote   @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@index([quote_id, position])
  @@map("quote_lines")
}

// BUSINESS RULE [CDC-2.1]: Module Ventes - Factures
model Invoice {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String    @db.Uuid
  client_id             String    @db.Uuid
  quote_id              String?   @db.Uuid
  number                String    // FAC-2026-00001
  type                  String    @default("standard") // standard, deposit, credit_note, situation
  status                String    @default("draft") // draft, finalized, sent, paid, partially_paid, overdue, cancelled
  issue_date            DateTime  @default(now())
  due_date              DateTime
  deposit_percent       Int?      // Pour facture d'acompte (basis points)
  situation_percent     Int?      // Pour situation de travaux (basis points)
  previous_situation_cents Int?   // Montant deja facture
  payment_terms         Int       @default(30)
  notes                 String?
  // F5 : escompte paiement anticipe (ex: 2% si paye sous 10 jours)
  early_payment_rate_bp   Int?    // taux escompte en basis points (200 = 2%)
  early_payment_days      Int?    // delai pour bénéficier de l'escompte
  // F5 : mentions legales figées au moment de la finalisation (audit legal)
  mentions_legales_snapshot Json?
  // F5 : signature electronique facture (eIDAS simple)
  e_signature_hash        String?
  e_signature_signed_at   DateTime?
  e_signature_signer      String? // email signataire employeur
  total_ht_cents        Int       @default(0)
  total_tva_cents       Int       @default(0)
  total_ttc_cents       Int       @default(0)
  paid_cents            Int       @default(0)
  remaining_cents       Int       @default(0)
  finalized_at          DateTime?
  paid_at               DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  tenant                Tenant    @relation(fields: [tenant_id], references: [id])
  client                Client    @relation(fields: [client_id], references: [id])
  quote                 Quote?    @relation(fields: [quote_id], references: [id])
  lines                 InvoiceLine[]
  payments              Payment[]

  @@unique([tenant_id, number])
  @@index([tenant_id, deleted_at])
  @@index([tenant_id, status])
  @@index([tenant_id, client_id])
  @@map("invoices")
}

model InvoiceLine {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id        String  @db.Uuid
  position          Int
  label             String
  description       String?
  quantity          Decimal @db.Decimal(10, 3)
  unit              String  @default("unit")
  unit_price_cents  Int     @default(0)
  tva_rate          Int     @default(2000)
  total_ht_cents    Int     @default(0)

  invoice           Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id, position])
  @@map("invoice_lines")
}

model Payment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  invoice_id      String   @db.Uuid
  amount_cents    Int
  payment_date    DateTime
  payment_method  String   // bank_transfer, card, cash, check
  reference       String?
  notes           String?
  created_at      DateTime @default(now())

  invoice         Invoice  @relation(fields: [invoice_id], references: [id])

  @@index([tenant_id])
  @@index([invoice_id])
  @@map("payments")
}

// BUSINESS RULE [CDC-2.2]: Module Achats - Fournisseurs
model Supplier {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  name            String
  siret           String?
  email           String?
  phone           String?
  address         Json?
  iban            String?
  bic             String?
  payment_terms   Int       @default(30)
  category        String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id])
  purchases       Purchase[]

  @@index([tenant_id, deleted_at])
  @@index([tenant_id, name])
  @@map("suppliers")
}

// BUSINESS RULE [CDC-2.2]: Module Achats - Factures fournisseurs
model Purchase {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String    @db.Uuid
  supplier_id       String?   @db.Uuid
  number            String?
  status            String    @default("pending") // pending, validated, paid, disputed
  source            String    @default("manual") // manual, ocr, email, connector
  issue_date        DateTime?
  due_date          DateTime?
  total_ht_cents    Int       @default(0)
  total_tva_cents   Int       @default(0)
  total_ttc_cents   Int       @default(0)
  paid_cents        Int       @default(0)
  category          String?
  notes             String?
  document_url      String?
  ocr_data          Json?
  ocr_confidence    Float?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  tenant            Tenant    @relation(fields: [tenant_id], references: [id])
  supplier          Supplier? @relation(fields: [supplier_id], references: [id])
  lines             PurchaseLine[]

  @@index([tenant_id, deleted_at])
  @@index([tenant_id, status])
  @@index([tenant_id, supplier_id])
  @@map("purchases")
}

model PurchaseLine {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchase_id       String  @db.Uuid
  position          Int
  label             String
  quantity          Decimal @db.Decimal(10, 3)
  unit_price_cents  Int     @default(0)
  tva_rate          Int     @default(2000)
  total_ht_cents    Int     @default(0)

  purchase          Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)

  @@index([purchase_id, position])
  @@map("purchase_lines")
}

// BUSINESS RULE [CDC-2.3]: Module Bancaire - Comptes bancaires
model BankAccount {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  provider_id     String?   // ID chez Bridge/Powens
  bank_name       String
  account_name    String?
  iban            String?
  bic             String?
  balance_cents   Int       @default(0)
  currency        String    @default("EUR")
  last_sync_at    DateTime?
  status          String    @default("active") // active, error, disconnected
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id])
  transactions    BankTransaction[]

  @@index([tenant_id, deleted_at])
  @@index([tenant_id, status])
  @@map("bank_accounts")
}

// BUSINESS RULE [CDC-2.3]: Module Bancaire - Transactions bancaires
model BankTransaction {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  bank_account_id String    @db.Uuid
  provider_id     String?   // ID chez le provider
  date            DateTime
  value_date      DateTime?
  amount_cents    Int
  currency        String    @default("EUR")
  label           String
  raw_label       String?   // Label brut de la banque
  category        String?
  type            String?   // credit, debit
  matched         Boolean   @default(false)
  invoice_id      String?   @db.Uuid
  purchase_id     String?   @db.Uuid
  created_at      DateTime  @default(now())

  bank_account    BankAccount @relation(fields: [bank_account_id], references: [id])

  @@index([tenant_id, bank_account_id])
  @@index([tenant_id, matched])
  @@index([tenant_id, date])
  @@index([bank_account_id, date])
  @@map("bank_transactions")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  user_id     String   @db.Uuid
  action      String
  entity_type String
  entity_id   String?  @db.Uuid
  old_values  Json?
  new_values  Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}

// ====================================================================
// DUERP — Document Unique d'Evaluation des Risques Professionnels
// BUSINESS RULE [CDC-2.4]: Module Legal et Conformite
// ====================================================================

model Duerp {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  company_name    String
  siret           String?
  naf_code        String?
  activity_label  String?
  employee_count  Int       @default(1)
  evaluator_name  String?
  evaluation_date DateTime  @default(now())
  status          String    @default("draft") // draft, validated, archived
  version         Int       @default(1)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant     Tenant @relation(fields: [tenant_id], references: [id])
  work_units DuerpWorkUnit[]
  archives   DuerpArchive[]
  papripact  Papripact?
  triggers   DuerpUpdateTrigger[]

  @@index([tenant_id, deleted_at])
  @@map("duerps")
}

model DuerpWorkUnit {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  duerp_id       String  @db.Uuid
  name           String
  description    String?
  employee_count Int     @default(1)

  risks DuerpRisk[]
  duerp Duerp     @relation(fields: [duerp_id], references: [id], onDelete: Cascade)

  @@index([duerp_id])
  @@map("duerp_work_units")
}

model DuerpRisk {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  work_unit_id        String  @db.Uuid
  category            String
  label               String
  description         String?
  gravity             Int     // 1-4
  probability         Int     // 1-4
  risk_level          Int     // gravity * probability
  exposure_situations Json?   // string[]
  health_consequences Json?   // string[]
  legal_references    Json?   // string[]
  residual_risk       Int?

  prevention_measures DuerpPreventionMeasure[]
  work_unit           DuerpWorkUnit @relation(fields: [work_unit_id], references: [id], onDelete: Cascade)

  @@index([work_unit_id])
  @@map("duerp_risks")
}

model DuerpPreventionMeasure {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  risk_id             String  @db.Uuid
  label               String
  type                String  // technical, organizational, individual, formation
  principle_level     Int     // 1-9 (L4121-2)
  priority            String  // immediate, short_term, medium_term
  responsible_role    String?
  verification_method String?
  status              String  @default("planned") // planned, in_progress, done

  risk DuerpRisk @relation(fields: [risk_id], references: [id], onDelete: Cascade)

  @@index([risk_id])
  @@map("duerp_prevention_measures")
}

// DUERP E8 — Triggers de mise a jour
model DuerpUpdateTrigger {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  duerp_id     String    @db.Uuid
  trigger_type String    // chemical_purchase, equipment_purchase, annual_review, accident, regulatory
  source_id    String?   @db.Uuid
  source_type  String?   // purchase, incident
  description  String
  severity     String    @default("info") // info, warning, critical
  status       String    @default("pending") // pending, acknowledged, resolved, dismissed
  created_at   DateTime  @default(now())
  resolved_at  DateTime?

  duerp Duerp @relation(fields: [duerp_id], references: [id])

  @@index([tenant_id, status])
  @@index([duerp_id])
  @@map("duerp_update_triggers")
}

// DUERP E9 — PAPRIPACT (Programme Annuel de Prevention)
model Papripact {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String   @db.Uuid
  duerp_id          String   @db.Uuid @unique
  year              Int
  status            String   @default("draft") // draft, validated, in_progress, completed
  total_budget_cents Int     @default(0)
  spent_cents       Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  actions PapripactAction[]
  duerp   Duerp @relation(fields: [duerp_id], references: [id])

  @@index([tenant_id])
  @@map("papripacts")
}

model PapripactAction {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  papripact_id    String    @db.Uuid
  risk_id         String?   @db.Uuid
  label           String
  type            String    // technical, organizational, formation, individual
  priority        String    // immediate, short_term, medium_term, long_term
  responsible     String?
  deadline        DateTime?
  budget_cents    Int       @default(0)
  spent_cents     Int       @default(0)
  status          String    @default("planned") // planned, in_progress, done, cancelled
  completion_date DateTime?

  papripact Papripact @relation(fields: [papripact_id], references: [id], onDelete: Cascade)

  @@index([papripact_id])
  @@map("papripact_actions")
}

// DUERP E10 — Archives (conservation 40 ans)
model DuerpArchive {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  duerp_id        String   @db.Uuid
  version         Int
  frozen_content  Json     // snapshot complet du DUERP
  content_hash    String   // SHA-256
  previous_hash   String?  // chaine de hash
  archived_at     DateTime @default(now())
  retention_until DateTime // archived_at + 40 ans

  access_logs DuerpArchiveAccessLog[]
  duerp       Duerp @relation(fields: [duerp_id], references: [id])

  @@index([tenant_id])
  @@index([duerp_id, version])
  @@map("duerp_archives")
}

model DuerpArchiveAccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  archive_id String   @db.Uuid
  user_id    String   @db.Uuid
  action     String   // view, download, export
  ip_address String?
  created_at DateTime @default(now())

  archive DuerpArchive @relation(fields: [archive_id], references: [id])

  @@index([archive_id])
  @@map("duerp_archive_access_logs")
}

// DUERP E11 — Formations
model TrainingRecord {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  employee_name   String
  training_code   String    // reference dans TRAININGS_DATABASE
  training_label  String
  obtained_date   DateTime
  expiry_date     DateTime?
  certificate_url String?
  status          String    @default("valid") // valid, expiring_soon, expired
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@index([tenant_id, expiry_date])
  @@map("training_records")
}

// DUERP E12 — EPI (Equipements de Protection Individuelle)
model EpiAssignment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  employee_name String
  epi_code      String    // reference dans PPE database
  epi_label     String
  assigned_date DateTime
  expiry_date   DateTime?
  en_norm       String?
  status        String    @default("assigned") // assigned, expired, replaced
  created_at    DateTime  @default(now())

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@map("epi_assignments")
}

// ====================================================================
// NF525 — Conformite anti-fraude TVA
// ====================================================================

// NF525 N2-N3 — Chaine de hash des factures
model InvoiceHashChain {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  invoice_id      String   @db.Uuid
  sequence_number Int
  content_hash    String   // SHA-256 du contenu facture
  previous_hash   String   // hash precedent ou GENESIS
  chain_hash      String   // SHA-256(content_hash + previous_hash)
  created_at      DateTime @default(now())

  @@unique([tenant_id, sequence_number])
  @@index([tenant_id])
  @@index([invoice_id])
  @@map("invoice_hash_chains")
}

// NF525 — Journal d'audit NF525
model Nf525AuditEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  action_type String   // creation, finalization, sending, payment, cancellation, export, verification
  entity_type String   // invoice, credit_note
  entity_id   String   @db.Uuid
  user_id     String   @db.Uuid
  hash_before String?
  hash_after  String?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([entity_type, entity_id])
  @@map("nf525_audit_entries")
}

// NF525 N1 — Factures entrantes
model IncomingInvoice {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String    @db.Uuid
  supplier_id       String?   @db.Uuid
  purchase_id       String?   @db.Uuid
  source            String    // upload, email, webhook
  status            String    @default("received") // received, validated, matched, accounted, rejected
  original_filename String?
  document_url      String?
  facturx_profile   String?   // MINIMUM, BASIC_WL, BASIC, EN16931, EXTENDED
  parsed_data       Json?     // ParsedFacturXInvoice
  sender_siret      String?
  sender_name       String?
  invoice_number    String?
  issue_date        DateTime?
  total_ht_cents    Int?
  total_tva_cents   Int?
  total_ttc_cents   Int?
  currency          String    @default("EUR")
  duplicate_of_id   String?   @db.Uuid
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([tenant_id, status])
  @@index([tenant_id, sender_siret])
  @@map("incoming_invoices")
}

// NF525 N4 — E-Reporting (B2C et international)
model EReportingEntry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  type            String    // b2c, international
  invoice_id      String?   @db.Uuid
  period          String    // 2026-01, 2026-Q1
  total_ht_cents  Int
  total_tva_cents Int
  tva_rate        Int
  status          String    @default("pending") // pending, sent, accepted, rejected
  ppf_reference   String?
  sent_at         DateTime?
  created_at      DateTime  @default(now())

  @@index([tenant_id, period])
  @@index([tenant_id, status])
  @@map("e_reporting_entries")
}

// ====================================================================
// Legal — RGPD et Assurances
// ====================================================================

// RGPD — Registre des traitements
model RgpdTreatment {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  name                String
  purpose             String
  legal_basis         String    // consent, contract, legal_obligation, vital_interest, public_interest, legitimate_interest
  data_categories     Json      // string[]
  data_subjects       Json      // string[]
  recipients          Json?     // string[]
  retention_days      Int?
  security_measures   Json?     // string[]
  transfer_outside_eu Boolean   @default(false)
  transfer_details    String?
  dpia_required       Boolean   @default(false)
  status              String    @default("active") // active, inactive, archived
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, deleted_at])
  @@map("rgpd_treatments")
}

// Assurances — Coffre-fort numerique
model InsurancePolicy {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String    @db.Uuid
  type                 String    // rc_pro, decennale, multirisque, auto, other
  insurer              String
  policy_number        String?
  start_date           DateTime
  end_date             DateTime
  premium_cents        Int?
  coverage_amount_cents Int?
  document_url         String?
  status               String    @default("active") // active, expiring_soon, expired
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  deleted_at           DateTime?

  @@index([tenant_id, deleted_at])
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, end_date])
  @@map("insurance_policies")
}

// ====================================================================
// Settings — Configuration par tenant
// ====================================================================

model TenantSettings {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  category   String   // accounting, payments, ppf, connectors
  data       Json     // configuration JSON
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, category])
  @@map("tenant_settings")
}

// ====================================================================
// HR — Effectif et gestion RH (conforme droit du travail FR)
// BUSINESS RULE [CDC-RH]: V1 Fondations — persistence reelle des employes
// ====================================================================

model HrPosition {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String    @db.Uuid
  name                  String
  slug                  String
  category              String    @default("other") // btp, restauration, commerce, etc.
  description           String?
  naf_code              String?
  convention_collective String?
  code_idcc             String?
  coefficient           String?   // grille conventionnelle
  echelon               String?
  classification        String?   // employe, ouvrier_qualifie, agent_maitrise, cadre
  equipment_used        Json      @default("[]") // string[]
  chemical_exposures    Json      @default("[]") // string[]
  physical_constraints  Json      @default("[]") // PhysicalConstraint[]
  work_schedule         Json      @default("{}") // WorkSchedule
  mandatory_trainings   Json      @default("[]") // TrainingRequirement[]
  medical_surveillance  String    @default("standard") // standard | enhanced
  target_headcount      Int       @default(1)
  work_unit_ids         Json      @default("[]")
  is_active             Boolean   @default(true)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  tenant    Tenant       @relation(fields: [tenant_id], references: [id])
  employees HrEmployee[]

  @@index([tenant_id, deleted_at])
  @@map("hr_positions")
}

model HrEmployee {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id              String    @db.Uuid
  position_id            String?   @db.Uuid
  // Identite
  first_name             String
  last_name              String
  birth_name             String?
  email                  String?
  phone                  String?
  birth_date             DateTime?
  birth_place            String?
  nationality            String    @default("FR")
  social_security_number String?   // format NIR FR (15 chars)
  // Adresse
  address_line1          String?
  zip_code               String?
  city                   String?
  country                String    @default("FR")
  // Contrat
  contract_type          String    // cdi | cdd | apprentissage | stage | interim | saisonnier
  cdd_reason             String?   // obligatoire si cdd
  start_date             DateTime
  end_date               DateTime? // requis cdd/apprenti/stage
  probation_end_date     DateTime?
  is_part_time           Boolean   @default(false)
  weekly_hours           Float     @default(35)
  monthly_gross_cents    Int       @default(0)
  // Obligations
  dpae_declared_at       DateTime?
  dpae_reference         String?
  contract_signed_at     DateTime?
  contract_document_url  String?
  // Sortie
  exit_date              DateTime?
  exit_reason            String?   // demission | licenciement | fin_cdd | rupture_conventionnelle | retraite | deces
  // Meta
  specific_restrictions  String?
  work_unit_ids          Json      @default("[]")
  is_active              Boolean   @default(true)
  // V6 : PAS (prelevement a la source)
  pas_rate_bp            Int       @default(0) // taux PAS en basis points (ex: 920 = 9.2%)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  deleted_at             DateTime?

  tenant         Tenant             @relation(fields: [tenant_id], references: [id])
  position       HrPosition?        @relation(fields: [position_id], references: [id])
  trainings      HrTrainingRecord[]
  medical_visits HrMedicalVisit[]
  leaves         HrLeaveRecord[]
  payslips       HrPayslip[]

  @@index([tenant_id, deleted_at])
  @@index([tenant_id, exit_date])
  @@map("hr_employees")
}

model HrTrainingRecord {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  employee_id     String    @db.Uuid
  training_code   String
  training_label  String
  obtained_date   DateTime
  expiry_date     DateTime?
  certificate_ref String?
  provider        String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  employee HrEmployee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, employee_id])
  @@index([expiry_date])
  @@map("hr_training_records")
}

model HrMedicalVisit {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  employee_id     String    @db.Uuid
  visit_type      String    // embauche | periodique | reprise | pre_reprise | occasionnelle
  visit_date      DateTime
  result          String?   // apte | apte_avec_reserves | inapte_temporaire | inapte
  restrictions    String?
  next_visit_date DateTime?
  medecin_name    String?
  created_at      DateTime  @default(now())

  employee HrEmployee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, employee_id])
  @@map("hr_medical_visits")
}

model HrLeaveRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  employee_id String   @db.Uuid
  leave_type  String   // cp | rtt | maladie | maternite | paternite | at | parental | formation | sans_solde
  start_date  DateTime
  end_date    DateTime
  days_taken  Float
  status      String   @default("approved") // requested | approved | rejected | taken
  notes       String?
  created_at  DateTime @default(now())

  employee HrEmployee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, employee_id])
  @@map("hr_leave_records")
}

model HrRegistryEntry {
  // Registre Unique du Personnel — append-only, audit legal
  // Article L1221-13 Code du travail
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  employee_id    String?  @db.Uuid // null si l'employe a ete supprime
  entry_type     String   // embauche | sortie | modification_contrat
  employee_name  String   // snapshot immuable
  position_name  String?
  contract_type  String?
  event_date     DateTime
  metadata       Json?    // snapshot des changements
  created_at     DateTime @default(now())
  created_by     String?  @db.Uuid

  @@index([tenant_id, event_date])
  @@map("hr_registry_entries")
}

// BUSINESS RULE [CDC-RH-V2]: Paie — periodes mensuelles + bulletins
// Conservation obligatoire 5 ans minimum (Article L3243-4 CT)

model HrPayrollPeriod {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  period_year  Int
  period_month Int
  closed_at    DateTime? // periode fermee = plus de modification
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  payslips HrPayslip[]

  @@unique([tenant_id, period_year, period_month])
  @@index([tenant_id, period_year, period_month])
  @@map("hr_payroll_periods")
}

model HrPayslip {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String @db.Uuid
  period_id   String @db.Uuid
  employee_id String @db.Uuid
  period_year  Int
  period_month Int
  // Rubriques brutes (centimes)
  gross_base_cents  Int
  overtime_cents    Int @default(0)
  bonus_cents       Int @default(0)
  indemnity_cents   Int @default(0)
  gross_total_cents Int
  // Cotisations salariales
  urssaf_employee_cents       Int
  retirement_employee_cents   Int
  unemployment_employee_cents Int @default(0)
  mutual_employee_cents       Int @default(0)
  csg_crds_cents              Int
  total_employee_deductions_cents Int
  // Net
  net_taxable_cents Int
  net_to_pay_cents  Int
  // Cotisations patronales (info)
  urssaf_employer_cents        Int
  retirement_employer_cents    Int
  unemployment_employer_cents  Int
  mutual_employer_cents        Int @default(0)
  total_employer_charges_cents Int
  // Reduction Fillon
  fillon_reduction_cents Int @default(0)
  // V5 : prevoyance
  prevoyance_employee_cents Int @default(0)
  prevoyance_employer_cents Int @default(0)
  // V5 : tickets restaurants
  tr_count            Int @default(0)
  tr_employee_cents   Int @default(0)
  tr_employer_cents   Int @default(0)
  // V6 : PAS + cumuls annuels
  pas_cents                 Int @default(0)
  ytd_gross_cents           Int @default(0)
  ytd_net_taxable_cents     Int @default(0)
  ytd_net_to_pay_cents      Int @default(0)
  // V7 : heures sup majorees + avantage nature + PPV + soldes
  overtime_25_hours         Float @default(0)
  overtime_50_hours         Float @default(0)
  overtime_25_cents         Int @default(0)
  overtime_50_cents         Int @default(0)
  benefits_in_kind_cents    Int @default(0)
  ppv_cents                 Int @default(0)
  cp_balance_end            Float @default(0)
  rtt_balance_end           Float @default(0)
  // V9 : arret maladie + transport
  sick_days_unpaid          Float @default(0)
  sick_deduction_cents      Int @default(0)
  ijss_cents                Int @default(0)
  transport_allowance_cents Int @default(0)
  // Meta
  gross_rate_cents_per_hour Int
  hours_worked              Float
  paid_leave_balance        Float @default(0)
  rtt_balance               Float @default(0)
  pdf_url                   String?
  sent_to_employee_at       DateTime?
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  period   HrPayrollPeriod @relation(fields: [period_id], references: [id])
  employee HrEmployee      @relation(fields: [employee_id], references: [id])

  @@unique([period_id, employee_id])
  @@index([tenant_id, period_year, period_month])
  @@map("hr_payslips")
}

// BUSINESS RULE [CDC-RH-V5]: Parametres paie par tenant — mutuelle / prevoyance
// Loi ANI 2013 : mutuelle collective obligatoire pour tous les salaries CDI/CDD
// Prevoyance : obligatoire pour cadres (convention 1947), facultatif autres sauf CC specifique

model HrPayrollSettings {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String @unique @db.Uuid

  // Mutuelle
  mutuelle_enabled          Boolean @default(false)
  mutuelle_employee_rate_bp Int     @default(0) // taux salarial en basis points (100 = 1%)
  mutuelle_employer_rate_bp Int     @default(0)
  mutuelle_flat_employee_cents Int @default(0) // ou montant forfaitaire (alternative au taux)
  mutuelle_flat_employer_cents Int @default(0)
  mutuelle_organisme        String? // Harmonie, Mercer, AG2R, etc.

  // Prevoyance
  prevoyance_enabled          Boolean @default(false)
  prevoyance_employee_rate_bp Int     @default(0)
  prevoyance_employer_rate_bp Int     @default(0)
  prevoyance_organisme        String?

  // Titres restaurants (bonus V5)
  tr_enabled            Boolean @default(false)
  tr_face_value_cents   Int     @default(0) // valeur faciale du titre (ex: 900 = 9 EUR)
  tr_employer_share_bp  Int     @default(5000) // 50% patronale (min 50%, max 60% exoneres)

  // V6 : taux AT-MP specifique notifie par CARSAT
  atmp_rate_bp Int @default(150) // 1.5% par defaut

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("hr_payroll_settings")
}

// V8 : Acces portail salarie (magic link)
model HrEmployeePortalAccess {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  employee_id  String   @unique @db.Uuid
  token_hash   String   @unique
  issued_at    DateTime @default(now())
  expires_at   DateTime
  last_used_at DateTime?
  revoked_at   DateTime?

  @@index([tenant_id, employee_id])
  @@map("hr_employee_portal_access")
}

// V8 : Signature electronique contrat (eIDAS simple)
model HrContractSignature {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  employee_id     String   @db.Uuid
  contract_type   String   // cdi, cdd, apprentice, intern
  signed_by_employer_at DateTime?
  employer_signature    String? // hash ou base64
  signed_by_employee_at DateTime?
  employee_signature    String?
  document_html         String @db.Text
  document_hash         String // SHA-256 document final
  status                String @default("pending") // pending | employer_signed | fully_signed | cancelled
  created_at            DateTime @default(now())

  @@index([tenant_id, employee_id])
  @@map("hr_contract_signatures")
}

// V6 : Declaration Sociale Nominative mensuelle
model HrDsnFiling {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String @db.Uuid
  period_year       Int
  period_month      Int
  filing_type       String // "monthly" | "event_exit" | "event_arret"
  status            String @default("draft") // draft | generated | transmitted
  generated_at      DateTime?
  transmitted_at    DateTime?
  payslips_count    Int @default(0)
  total_gross_cents Int @default(0)
  total_urssaf_cents Int @default(0)
  payload           Json
  created_at        DateTime @default(now())

  @@index([tenant_id, period_year, period_month])
  @@map("hr_dsn_filings")
}
