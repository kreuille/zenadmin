  dpae_reference         String?
  contract_signed_at     DateTime?
  contract_document_url  String?
  // Sortie
  exit_date              DateTime?
  exit_reason            String?   // demission | licenciement | fin_cdd | rupture_conventionnelle | retraite | deces
  // Meta
