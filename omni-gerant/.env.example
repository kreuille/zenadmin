# =============================================================================
# Omni-Gerant - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgresql://omnigerant:omnigerant_dev@localhost:5432/omnigerant

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Encryption (AES-256) ---
ENCRYPTION_KEY=change-me-to-a-random-32-char-string-minimum

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# --- GoCardless ---
GOCARDLESS_ACCESS_TOKEN=sandbox_...
GOCARDLESS_ENV=sandbox
GOCARDLESS_WEBHOOK_SECRET=

# --- PPF (Portail Public de Facturation) ---
PPF_API_URL=https://api-sandbox.ppf.gouv.fr
PPF_API_KEY=
PPF_TECHNICAL_ID=
PPF_WEBHOOK_SECRET=
PPF_ENV=sandbox

# --- Bridge (Open Banking) ---
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=
BRIDGE_API_URL=https://api.bridgeapi.io/v2
BRIDGE_WEBHOOK_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@omni-gerant.fr

# --- OCR Service ---
OCR_SERVICE_URL=http://localhost:8000

# --- S3 Storage ---
S3_ENDPOINT=
S3_BUCKET=omni-gerant
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-3

# --- Kiwiz NF525 ---
KIWIZ_API_URL=https://api.kiwiz.io
KIWIZ_USERNAME=
KIWIZ_PASSWORD=
KIWIZ_SUBSCRIPTION_ID=
