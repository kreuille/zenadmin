{
  "name": "@omni-gerant/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit --skipLibCheck || true",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@omni-gerant/db": "workspace:*",
    "@omni-gerant/shared": "workspace:*",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.0",
    "jsonwebtoken": "^9.0.3",
    "otpauth": "^9.5.0",
    "pino": "^9.0.0",
    "tsx": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
